# Normaliza line endings entre Windows e Unix
* text=auto eol=lf

# Texto explícito
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf

# Binários (sem conversão)
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.svg    binary
*.ico    binary
*.webp   binary
*.woff   binary
*.woff2  binary
*.pdf    binary
